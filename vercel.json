{
  "version": 2,
  "buildCommand": "npm run build --workspace=web && npx prisma generate --schema=apps/api-bot/prisma/schema.prisma",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
